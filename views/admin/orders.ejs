<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>배송 상태 관리 - Refresh Beverage Mall</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Apple SD Gothic Neo", "Noto Sans KR", system-ui, sans-serif; -webkit-font-smoothing: antialiased; margin: 0; padding: 40px; background-color: #f8fafc; color: #1e293b; }
        .admin-container { max-width: 1100px; margin: 0 auto; background: white; padding: 40px; border-radius: 16px; border: 1px solid #e2e8f0; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05); }
        .board-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 35px; border-bottom: 2px solid #0f172a; padding-bottom: 20px; }
        h2 { font-size: 24px; font-weight: 800; color: #0f172a; margin: 0; }
        .btn-home { color: #64748b; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 6px; }
        .btn-home:hover { color: #0f172a; text-decoration: underline; }

        .management-table { width: 100%; border-collapse: collapse; font-size: 14px; margin-bottom: 20px; }
        .management-table th { background-color: #f1f5f9; color: #475569; font-weight: 700; padding: 16px 12px; border-bottom: 2px solid #e2e8f0; text-align: center; }
        .management-table td { padding: 16px 12px; border-bottom: 1px solid #e2e8f0; text-align: center; vertical-align: middle; color: #334155; }
        .management-table tr:hover { background-color: #f8fafc; }
        .prod-id { font-family: monospace; color: #94a3b8; font-weight: 600; }

        .status-select { padding: 8px 12px; font-weight: 600; border: 1px solid #cbd5e1; border-radius: 6px; background-color: #fff; color: #334155; cursor: pointer; transition: 0.2s; }
        .status-select:focus { outline: none; border-color: #0ea5e9; }

        .btn-batch-save { background-color: #10b981; color: white; border: none; padding: 12px 24px; border-radius: 8px; font-weight: bold; cursor: pointer; font-size: 15px; width: 100%; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2); transition: 0.2s; }
        .btn-batch-save:hover { background-color: #059669; }

        footer { margin-top: 50px; text-align: center; font-size: 13px; color: #94a3b8; }
    </style>
</head>
<body>
<div class="admin-container">
    <header class="board-header">
        <h2>🚚 고객 주문 및 배송 상태 일괄 처리장</h2>
        <a href="/admin" class="btn-home">⬅ 대시보드로 복귀</a>
    </header>

    <main>
        <!-- 💡 일괄 수정을 위해 전체 테이블을 form으로 감쌉니다 -->
        <form action="/admin/orders/update-batch" method="POST">
            <table class="management-table">
                <thead>
                <tr>
                    <th style="width: 15%;">주문번호</th>
                    <th style="width: 25%;">고객 정보</th>
                    <th style="width: 15%;">총 결제액</th>
                    <th style="width: 20%;">주문 접수일</th>
                    <th style="width: 25%;">배송 상태 (변경)</th>
                </tr>
                </thead>
                <tbody>
                <% if (orders && orders.length > 0) { %>
                    <% orders.forEach(order => { %>
                        <tr>
                            <td class="prod-id">
                                #<%= order.order_id %>
                                <input type="hidden" name="orderIds" value="<%= order.order_id %>">
                            </td>
                            <td style="font-weight: 700;"><%= order.user_name %> <span style="font-size:12px; color:#64748b;">(<%= order.username %>)</span></td>
                            <td style="font-weight: 600; color: #0ea5e9;">₩<%= order.total_price.toLocaleString() %></td>
                            <td style="font-size: 13px; color: #64748b;"><%= order.created_at.substring(0, 16) %></td>
                            <td>
                                <select class="status-select" name="newStatuses">
                                    <option value="배송준비중" <%= order.status === '배송준비중' ? 'selected' : '' %>>📦 배송준비중</option>
                                    <option value="배송중" <%= order.status === '배송중' ? 'selected' : '' %>>🚚 배송중</option>
                                    <option value="배송완료" <%= order.status === '배송완료' ? 'selected' : '' %>>✅ 배송완료 (완료시 목록 제외)</option>
                                </select>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="5" style="padding: 50px; color: #94a3b8;">현재 처리해야 할 활성 주문이 없습니다.</td></tr>
                <% } %>
                </tbody>
            </table>

            <% if (orders && orders.length > 0) { %>
                <button type="submit" class="btn-batch-save">현재 배송 상태 일괄 저장하기</button>
            <% } %>
        </form>
    </main>
    <footer>&copy; 2026 시스템 관리 센터. All rights reserved.</footer>
</div>
</body>
</html>