<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Refresh Beverage Mall</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <style>
        /* 💡 현대적인 이커머스 전용 기본 베이스 스타일링 */
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Malgun Gothic", "맑은 고딕", helvetica, sans-serif;
            margin: 0; padding: 0;
            background-color: #f8fafc;
            color: #1e293b;
            -webkit-font-smoothing: antialiased;
        }

        /* 💡 1단: 쇼핑몰 유틸리티 팝 바 */
        .top-utility-bar {
            background-color: #0f172a;
            color: #cbd5e1;
            padding: 10px 60px;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 20px;
            font-size: 13px;
        }
        .user-welcome {
            font-weight: 500;
            color: #94a3b8;
        }
        .user-welcome strong {
            color: #38bdf8;
        }
        .top-link {
            color: #cbd5e1;
            text-decoration: none;
            transition: color 0.2s;
        }
        .top-link:hover {
            color: #ffffff;
        }
        .badge-admin {
            background-color: #ef4444;
            color: white;
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: bold;
        }

        /* 💡 2단: 메인 내비게이션 헤더 바 (GNB) */
        .main-gnb-header {
            background-color: #ffffff;
            border-bottom: 1px solid #e2e8f0;
            padding: 20px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
        }
        .brand-logo {
            font-size: 24px;
            font-weight: 800;
            color: #0f172a;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            letter-spacing: -0.5px;
        }
        .brand-logo span {
            color: #0ea5e9;
        }
        .nav-menu-group {
            display: flex;
            gap: 45px;
        }
        .nav-item {
            color: #475569;
            text-decoration: none;
            font-size: 16px;
            font-weight: 700;
            padding: 8px 0;
            position: relative;
            transition: color 0.2s;
        }
        .nav-item:hover, .nav-item.active {
            color: #0ea5e9;
        }
        .nav-item.active::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; width: 100%; height: 3px;
            background-color: #0ea5e9;
            border-radius: 2px;
        }

        /* 💡 레이아웃 메인 레이어 메인 영역 */
        .mall-contents-body {
            max-width: 1300px;
            margin: 0 auto;
            padding: 40px 60px;
        }

        /* 💡 쇼핑몰 시그니처 대형 와이드 히어로 배너 박스 디자인 */
        .hero-billboard {
            background: linear-gradient(135deg, #e0f2fe 0%, #f0fdf4 100%);
            border-radius: 16px;
            padding: 50px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            text-align: left;
            margin-bottom: 50px;
            border: 1px solid #bae6fd;
            position: relative;
            overflow: hidden;
        }
        .billboard-text-zone {
            z-index: 2;
            max-width: 550px;
        }
        .billboard-tag {
            display: inline-block;
            background-color: #0ea5e9;
            color: white;
            font-size: 12px;
            font-weight: bold;
            padding: 4px 10px;
            border-radius: 20px;
            margin-bottom: 15px;
            text-transform: uppercase;
        }
        .billboard-text-zone h2 {
            font-size: 32px;
            font-weight: 800;
            color: #0f172a;
            margin: 0 0 15px 0;
            line-height: 1.3;
        }
        .billboard-text-zone p {
            font-size: 16px;
            color: #475569;
            margin: 0 0 25px 0;
            height: 24px;
            font-weight: 500;
        }
        .btn-billboard-action {
            display: inline-block;
            background-color: #0f172a;
            color: white;
            padding: 14px 35px;
            font-size: 15px;
            font-weight: bold;
            text-decoration: none;
            border-radius: 8px;
            transition: background-color 0.2s, transform 0.2s;
        }
        .btn-billboard-action:hover {
            background-color: #1e293b;
            transform: translateY(-2px);
        }
        .billboard-img-zone {
            z-index: 2;
        }
        .billboard-img-zone img {
            width: 260px;
            height: auto;
            filter: drop-shadow(0 20px 25px rgba(0,0,0,0.08));
        }

        /* 💡 상품 리스트 섹션 헤더 디자인 */
        .section-headline-bar {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            border-bottom: 2px solid #0f172a;
            padding-bottom: 15px;
            margin-bottom: 30px;
        }
        .section-headline-bar h3 {
            font-size: 22px;
            font-weight: 800;
            color: #0f172a;
            margin: 0;
        }
        .section-sub-link {
            color: #64748b;
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
        }
        .section-sub-link:hover {
            color: #0ea5e9;
            text-decoration: underline;
        }

        /* 💡 스마트 4열 카드 그리드 레이아웃 */
        .shopping-item-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 25px;
        }
        .shopping-card-box {
            background-color: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .shopping-card-box:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 20px -5px rgba(0, 0, 0, 0.08);
            border-color: #cbd5e1;
        }
        .card-img-wrapper {
            width: 100%;
            height: 220px;
            background-color: #f1f5f9;
            overflow: hidden;
            position: relative;
        }
        .card-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s;
        }
        .shopping-card-box:hover .card-img-wrapper img {
            transform: scale(1.04);
        }

        .card-info-content {
            padding: 20px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            text-align: left;
        }
        .card-info-content h4 {
            font-size: 16px;
            font-weight: 700;
            color: #0f172a;
            margin: 0 0 6px 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .card-info-content p {
            font-size: 13px;
            color: #64748b;
            margin: 0 0 15px 0;
            line-height: 1.4;
            height: 36px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .card-price-line {
            margin-top: auto;
            font-size: 18px;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 15px;
        }

        .card-btn-group {
            display: flex;
            gap: 6px;
        }
        .btn-action-cart {
            flex-grow: 1;
            background-color: #0f172a;
            color: white;
            border: none;
            padding: 10px;
            font-size: 13px;
            font-weight: 700;
            border-radius: 6px;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        .btn-action-cart:hover {
            background-color: #1e293b;
        }
        .btn-action-wish {
            background-color: #fff;
            color: #cbd5e1;
            border: 1px solid #e2e8f0;
            padding: 10px 12px;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-action-wish:hover {
            border-color: #fda4af;
            color: #f43f5e;
            background-color: #fff1f2;
        }

        .mall-footer-layer {
            background-color: #0f172a;
            color: #94a3b8;
            padding: 40px 60px;
            margin-top: 100px;
            text-align: center;
            font-size: 14px;
            border-top: 1px solid #1e293b;
        }
        .mall-footer-layer p { margin: 0; }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const slogans = [
                "날이 너무 더울 땐 바로바로 시원한 음료수!",
                "에너지 드링크 먹고 시험 대박나자!",
                "우는아이도 뚝 그치게 하는 달달한 그 맛!",
                "엄마 미안해. 난 음료수가 더 좋아!"
            ];
            const bannerText = document.getElementById("banner-text");
            let index = 0;
            setInterval(() => {
                index = (index + 1) % slogans.length;
                if(bannerText) bannerText.textContent = slogans[index];
            }, 3000);
        });
    </script>
</head>
<body>

<div class="top-utility-bar">
    <% if (user) { %>
        <span class="user-welcome">안녕하세요, <strong><%= user.username %></strong>님!</span>
        <% if (user.role === 'ADMIN') { %>
            <a href="/admin" class="top-link font-bold"><span class="badge-admin">ADMIN</span> 관리실</a>
        <% } %>
        <a href="/mypage" class="top-link">마이페이지</a>
        <a href="/user/logout" class="top-link" style="color: #f43f5e;">로그아웃</a>
    <% } else { %>
        <span class="user-welcome">방문객님 환영합니다!</span>
        <a href="/user/login" class="top-link">로그인</a>
        <a href="/user/register" class="top-link">회원가입</a>
    <% } %>
</div>

<header class="main-gnb-header">
    <a href="/" class="brand-logo">Refresh <span>Beverage</span></a>
    <nav class="nav-menu-group">
        <a href="/" class="nav-item active">홈</a>
        <a href="/products" class="nav-item">상품목록</a>
        <a href="/cart" class="nav-item">장바구니</a>
        <a href="/board" class="nav-item">고객센터</a>
    </nav>
</header>

<div class="mall-contents-body">

    <section class="hero-billboard">
        <div class="billboard-text-zone">
            <h2>난 음료수가 없으면<br>인생을 어떻게 살았을까?</h2>
            <p id="banner-text">날이 덥고 짜증날땐 시원한 음료수 한잔!</p>
            <a href="/products" class="btn-billboard-action">지금 구매하기 →</a>
        </div>
        <div class="billboard-img-zone">
            <img src="/images/drink.png" alt="Beverage Premium Main Image">
        </div>
    </section>

    <section style="margin-top: 60px;">
        <div class="section-headline-bar">
            <h3>🔥 이 달의 인기 음료 추천</h3>
            <a href="/products" class="section-sub-link">전체 상품 보러가기 &gt;</a>
        </div>

        <div class="shopping-item-grid">
            <% if (typeof featuredProducts !== 'undefined' && featuredProducts.length > 0) { %>
                <% featuredProducts.forEach(product => { %>
                    <div class="shopping-card-box">
                        <div class="card-img-wrapper">
                            <img src="/images/<%= product.image || 'default.png' %>" alt="<%= product.name %>">
                        </div>
                        <div class="card-info-content">
                            <h4><%= product.emoji || '🍹' %> <%= product.name %></h4>
                            <p><%= product.description %></p>
                            <div class="card-price-line">
                                ₩<%= product.price.toLocaleString() %>
                            </div>

                            <div class="card-btn-group">
                                <form action="/cart/add" method="POST" style="margin:0; flex-grow:1;">
                                    <input type="hidden" name="productId" value="<%= product.id %>">
                                    <button type="submit" class="btn-action-cart">🛒 장바구니</button>
                                </form>
                                <form action="/wishlist/add" method="POST" style="margin:0;">
                                    <input type="hidden" name="productId" value="<%= product.id %>">
                                    <button type="submit" class="btn-action-wish">❤️</button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div style="grid-column: 1/-1; text-align: center; padding: 60px 0; color: #94a3b8; background: white; border-radius: 12px; border: 1px solid #e2e8f0; font-size: 15px; font-weight: 500;">
                    현재 진열된 인기 음료 추천 상품이 등록되지 않았습니다.
                </div>
            <% } %>
        </div>
    </section>
</div>

<footer class="mall-footer-layer">
    <p>&copy; 2026 Refresh Beverage Mall. All rights reserved.</p>
</footer>

</body>
</html>