<!DOCTYPE html>
<html>
<head>
    <title>마이페이지</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <style>
        .mypage-container { max-width: 600px; margin: 50px auto; padding: 20px; border: 1px solid #ddd; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        .info-group { margin-bottom: 15px; border-bottom: 1px solid #eee; padding-bottom: 10px; }
        .label { font-weight: bold; color: #666; width: 100px; display: inline-block; }
        .btn-group { margin-top: 25px; display: flex; gap: 10px; }
        .btn-home { display: inline-block; padding: 10px 20px; background-color: #facc15; color: #000; text-decoration: none; border-radius: 5px; font-weight: bold; }
        .btn-edit { display: inline-block; padding: 10px 20px; background-color: #4b5563; color: #fff; text-decoration: none; border-radius: 5px; font-weight: bold; }
        .btn-edit:hover { background-color: #374151; }

        /* 💡 탈퇴 버튼용 강렬한 다크레드 스타일 */
        .btn-withdraw { padding: 10px 20px; background-color: #dc2626; color: #fff; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; font-family: inherit; }
        .btn-withdraw:hover { background-color: #b91c1c; }

        ul { padding-left: 20px; }
        li { margin-bottom: 8px; }
        li a { color: #2563eb; text-decoration: none; font-weight: 500; }
        li a:hover { text-decoration: underline; }
    </style>
</head>
<body>
<div class="mypage-container">
    <h2>👤 내 정보 (마이페이지)</h2>
    <div class="info-group">
        <span class="label">아이디:</span> <span><%= user.username %></span>
    </div>
    <div class="info-group">
        <span class="label">이름:</span> <span><%= user.name %></span>
    </div>
    <div class="info-group">
        <span class="label">이메일:</span> <span><%= user.email %></span>
    </div>
    <div class="info-group">
        <span class="label">연락처:</span> <span><%= user.phone %></span>
    </div>
    <div class="info-group">
        <span class="label">주소지:</span> <span><%= user.address %></span>
    </div>

    <h3>활동 메뉴</h3>
    <ul>
        <li><a href="/cart">🛒 나의 장바구니 보기</a></li>
        <li><a href="/wishlist">❤️ 나의 위시리스트(찜) 보기</a></li>
        <li><a href="/order/history">📜 나의 주문 내역 확인</a></li>
        <li><a href="/board">내가 쓴 문의글 확인</a></li>
    </ul>

    <div class="btn-group">
        <a href="/" class="btn-home">🏠 홈으로 돌아가기</a>
        <a href="/user/edit" class="btn-edit">⚙️ 정보 수정하기</a>

        <form action="/user/withdraw-submit" method="POST" onsubmit="return confirm('🚨 정말로 탈퇴하시겠습니까?\n탈퇴 시 장바구니와 위시리스트가 잠기며, 재가입 절차가 필요합니다.')" style="margin:0; padding:0;">
            <button type="submit" class="btn-withdraw">🚨 회원 탈퇴하기</button>
        </form>
    </div>
</div>
</body>
</html>