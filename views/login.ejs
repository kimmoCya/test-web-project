<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>로그인 - Refresh Beverage Mall</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <style>
        /* 💡 현대적인 이커머스 전용 기본 베이스 스타일링 */
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Malgun Gothic", "맑은 고딕", helvetica, sans-serif;
            margin: 0; padding: 0;
            background-color: #f8fafc;
            color: #1e293b;
            -webkit-font-smoothing: antialiased;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* 💡 1단: 쇼핑몰 유틸리티 팝 바 (index와 100% 동일 사양 매칭) */
        .top-utility-bar {
            background-color: #0f172a;
            color: #cbd5e1;
            padding: 10px 60px;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 20px;
            font-size: 13px;
        }
        .user-welcome {
            font-weight: 500;
            color: #94a3b8;
        }
        .top-link {
            color: #cbd5e1;
            text-decoration: none;
            transition: color 0.2s;
        }
        .top-link:hover {
            color: #ffffff;
        }

        /* 💡 2단: 메인 내비게이션 헤더 바 (GNB 프레임 일치화) */
        .main-gnb-header {
            background-color: #ffffff;
            border-bottom: 1px solid #e2e8f0;
            padding: 20px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
        }
        .brand-logo {
            font-size: 24px;
            font-weight: 800;
            color: #0f172a;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            letter-spacing: -0.5px;
        }
        .brand-logo span {
            color: #0ea5e9;
        }
        .nav-menu-group {
            display: flex;
            gap: 45px;
        }
        .nav-item {
            color: #475569;
            text-decoration: none;
            font-size: 16px;
            font-weight: 700;
            padding: 8px 0;
            position: relative;
            transition: color 0.2s;
        }
        .nav-item:hover {
            color: #0ea5e9;
        }

        /* 💡 메인 콘텐츠 레이아웃 영역 (중앙 정렬) */
        .login-contents-body {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 60px 20px;
        }

        /* 💡 깔끔하고 현대적인 쇼핑몰 양식의 로그인 카드 박스 */
        .login-card-box {
            background-color: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
            box-sizing: border-box;
            text-align: center;
        }

        .login-card-box h2 {
            font-size: 24px;
            font-weight: 800;
            color: #0f172a;
            margin: 0 0 8px 0;
            letter-spacing: -0.5px;
        }

        .login-sub-text {
            font-size: 14px;
            color: #64748b;
            margin-bottom: 30px;
        }

        /* 💡 폼 입력 필드 세팅 */
        .form-group {
            margin-bottom: 16px;
            text-align: left;
        }

        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            color: #475569;
            margin-bottom: 6px;
        }

        input[type="text"], input[type="password"] {
            width: 100%;
            padding: 12px 14px;
            box-sizing: border-box;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            font-size: 14px;
            background-color: #fff;
            color: #0f172a;
            transition: all 0.2s;
        }

        /* 입력창에 마우스 커서나 포커스가 닿을 때 시안 블루 컬러 포인트 매칭 */
        input[type="text"]:focus, input[type="password"]:focus {
            outline: none;
            border-color: #0ea5e9;
            box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.12);
        }

        /* 💡 메인 로그인 버튼 (시안 블루 브랜드 컬러 연동) */
        .btn-login-submit {
            width: 100%;
            background-color: #0f172a;
            color: white;
            padding: 14px;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 10px;
            transition: background-color 0.2s, transform 0.1s;
        }

        .btn-login-submit:hover {
            background-color: #1e293b;
        }

        .btn-login-submit:active {
            transform: scale(0.99);
        }

        /* 💡 하단 회원가입 및 이동 보조 링크 가이드 */
        .login-helper-zone {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #f1f5f9;
            font-size: 13px;
        }

        .link-register {
            color: #0ea5e9;
            text-decoration: none;
            font-weight: 700;
        }

        .link-register:hover {
            text-decoration: underline;
        }

        .link-back-home {
            color: #64748b;
            text-decoration: none;
            font-weight: 500;
        }

        .link-back-home:hover {
            color: #0f172a;
            text-decoration: underline;
        }

        /* 💡 하단 푸터 레이아웃 */
        .mall-footer-layer {
            background-color: #0f172a;
            color: #94a3b8;
            padding: 40px 60px;
            text-align: center;
            font-size: 14px;
            border-top: 1px solid #1e293b;
        }
    </style>
</head>
<body>

<div class="top-utility-bar">
    <span class="user-welcome">방문객님 환영합니다!</span>
    <a href="/user/login" class="top-link font-bold" style="color: #0ea5e9;">로그인</a>
    <a href="/user/register" class="top-link">회원가입</a>
</div>

<header class="main-gnb-header">
    <a href="/" class="brand-logo">🥤 Refresh <span>Beverage</span></a>
    <nav class="nav-menu-group">
        <a href="/" class="nav-item">홈</a>
        <a href="/products" class="nav-item">상품목록</a>
        <a href="/cart" class="nav-item">장바구니</a>
        <a href="/board" class="nav-item">고객센터</a>
    </nav>
</header>

<div class="login-contents-body">

    <div class="login-card-box">
        <h2>로그인</h2>
        <p class="login-sub-text">Refresh Beverage Mall에 오신 것을 환영합니다.</p>

        <form action="/user/login" method="post">
            <div class="form-group">
                <label for="username">아이디</label>
                <input type="text" id="username" name="username" placeholder="아이디를 입력하세요" required>
            </div>

            <div class="form-group">
                <label for="password">비밀번호</label>
                <input type="password" id="password" name="password" placeholder="비밀번호를 입력하세요" required>
            </div>

            <button type="submit" class="btn-login-submit">로그인</button>
        </form>

        <div class="login-helper-zone">
            <span>아직 회원이 아니신가요? <a href="/user/register" class="link-register">회원가입</a></span>
            <a href="/" class="link-back-home">🏠 홈으로</a>
        </div>
    </div>

</div>

<footer class="mall-footer-layer">
    <p>&copy; 2026 Refresh Beverage Mall. All rights reserved.</p>
</footer>

</body>
</html>