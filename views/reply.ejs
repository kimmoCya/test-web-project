<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>답글 작성 - 고객센터</title>
    <style>
        body {
            font-family: 'Noto Sans KR', sans-serif;
            margin: 0;
            padding: 40px;
            background-color: #f8fafc;
            color: #334155;
        }

        .reply-container {
            max-width: 700px;
            margin: 0 auto;
            background: white;
            padding: 35px;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        }

        h2 {
            font-size: 22px;
            font-weight: 700;
            color: #1e293b;
            margin-top: 0;
            margin-bottom: 20px;
            border-left: 5px solid #10b981;
            padding-left: 12px;
        }

        .parent-post-info {
            background-color: #f0fdf4;
            border: 1px solid #bbf7d0;
            padding: 14px 18px;
            border-radius: 8px;
            font-size: 14px;
            color: #166534;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .parent-post-info strong {
            background-color: #10b981;
            color: white;
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 11px;
        }

        label {
            font-size: 14px;
            font-weight: 600;
            color: #475569;
            display: block;
            margin-bottom: 8px;
        }

        input[type="text"], textarea {
            width: 100%;
            padding: 12px;
            font-size: 14px;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            box-sizing: border-box;
            margin-bottom: 20px;
            transition: all 0.2s;
            background-color: #fff;
        }
        input[type="text"]:focus, textarea:focus {
            outline: none;
            border-color: #10b981;
            box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
        }

        .form-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 10px;
        }

        .btn-submit {
            background-color: #10b981;
            color: white;
            border: none;
            padding: 10px 24px;
            font-size: 14px;
            font-weight: bold;
            border-radius: 6px;
            cursor: pointer;
            box-shadow: 0 2px 4px rgba(16, 185, 129, 0.15);
            transition: background 0.2s;
        }
        .btn-submit:hover {
            background-color: #059669;
        }

        .btn-back {
            color: #64748b;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
        }
        .btn-back:hover {
            color: #1e293b;
            text-decoration: underline;
        }

        footer {
            margin-top: 40px;
            text-align: center;
            font-size: 12px;
            color: #94a3b8;
        }
    </style>
</head>
<body>

<div class="reply-container">
    <h2>💬 답글 작성</h2>

    <div class="parent-post-info">
        <strong>원글</strong> <span><%= parentTitle %></span>
    </div>

    <form action="/board/create" method="post">
        <input type="hidden" name="parent_id" value="<%= parentId %>">

        <label for="author">👤 작성자</label>
        <input type="text" id="author" name="author" placeholder="이름을 입력하세요" value="<%= (typeof user !== 'undefined' && user) ? user.username : '익명' %>" required>

        <label for="title">📝 답글 제목</label>
        <input type="text" id="title" name="title" placeholder="제목을 입력하세요" value="RE: <%= parentTitle %>" required>

        <label for="content">💬 답글 내용</label>
        <textarea id="content" name="content" placeholder="답글 내용을 상세히 작성해 주세요." rows="10" required></textarea>

        <div class="form-actions">
            <!-- 목록 대신 원래 보던 상세 글로 바로 돌아갈 수 있게 센스있게 주소를 맞춰줍니다 -->
            <a href="/board/view/<%= parentId %>" class="btn-back">← 원글로 돌아가기</a>
            <button type="submit" class="btn-submit">💚 답글 등록</button>
        </div>
    </form>
</div>

<footer>
    &copy; 2026 고객센터 시스템. All rights reserved.
</footer>

</body>
</html>